# Database Connection URL (Render provides Internal URL or External URL starting with postgres:// or postgresql://)
DATABASE_URL=postgresql://postgres:password@localhost:5432/bookstore_erp

# JWT Authentication
SECRET_KEY=replace_with_a_long_secure_random_string_in_production_32_chars_min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS & Frontend URLs
FRONTEND_URL=https://shelfiq.vercel.app
CORS_ORIGINS=https://shelfiq.vercel.app,http://localhost:5173

# Profile Image Uploads (Development disk storage vs Cloudinary production)
BACKEND_URL=https://bookstore-erp-backend.onrender.com
UPLOAD_DIR=uploads/profiles

# Cloudinary (Optional Production Image Storage)
# CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# SMTP Email Configuration (Optional - for Forgot Password delivery)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-gmail-app-password
